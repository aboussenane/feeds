# Public URL served by Caddy (not a Vercel deployment URL)
NEXT_PUBLIC_SITE_URL=https://feeds.example.com
# Public Caddy route to the shared self-hosted Supabase API
NEXT_PUBLIC_SUPABASE_URL=https://supabase.adeljs.dev
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Docker-internal direct PostgreSQL connection; obtain the password from the
# shared Supabase deployment and do not commit it.
DATABASE_URL=postgresql://postgres:<password>@supabase-db:5432/postgres
DIRECT_URL=postgresql://postgres:<password>@supabase-db:5432/postgres
